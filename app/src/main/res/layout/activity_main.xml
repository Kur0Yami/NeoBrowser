<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- Toolbar container with bottom shadow -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_toolbar"
        android:elevation="12dp">

        <!-- Status bar spacer -->
        <View
            android:id="@+id/status_bar_space"
            android:layout_width="match_parent"
            android:layout_height="0dp"/>

        <!-- Main toolbar row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:gravity="center_vertical">

            <!-- Back button - pill shaped touch target -->
            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_back"
                android:background="@drawable/btn_nav_bg"
                android:alpha="0.35"
                android:tint="@color/icon_color"
                android:contentDescription="Back"
                android:padding="10dp"/>

            <!-- Forward button -->
            <ImageButton
                android:id="@+id/btn_forward"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_forward"
                android:background="@drawable/btn_nav_bg"
                android:alpha="0.35"
                android:tint="@color/icon_color"
                android:contentDescription="Forward"
                android:padding="10dp"
                android:layout_marginStart="2dp"/>

            <!-- URL Bar - modern pill shape -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/url_bar_bg"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <!-- Lock / search icon -->
                <ImageView
                    android:id="@+id/icon_secure"
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:src="@drawable/ic_search"
                    android:tint="@color/accent"
                    android:layout_marginEnd="8dp"/>

                <EditText
                    android:id="@+id/url_bar"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="Search or enter URL"
                    android:textColorHint="@color/text_hint"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:singleLine="true"
                    android:inputType="textUri"
                    android:imeOptions="actionGo"
                    android:selectAllOnFocus="true"/>
            </LinearLayout>

            <!-- Tabs button with badge -->
            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp">

                <ImageButton
                    android:id="@+id/btn_tabs"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_grid"
                    android:background="@drawable/btn_nav_bg"
                    android:tint="@color/icon_color"
                    android:contentDescription="Tabs"
                    android:padding="10dp"/>

                <TextView
                    android:id="@+id/tab_count"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="2dp"
                    android:background="@drawable/tab_count_bg"
                    android:text="1"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:gravity="center"/>
            </FrameLayout>

            <!-- Menu button -->
            <ImageButton
                android:id="@+id/btn_menu"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_more"
                android:background="@drawable/btn_nav_bg"
                android:tint="@color/icon_color"
                android:contentDescription="Menu"
                android:padding="10dp"
                android:layout_marginStart="2dp"/>

        </LinearLayout>

        <!-- Loading progress bar - accent color gradient line -->
        <ProgressBar
            android:id="@+id/progress_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:max="100"
            android:progressTint="@color/accent"
            android:progressBackgroundTint="@color/progress_bg"
            android:visibility="gone"/>

    </LinearLayout>

    <!-- WebView fills remaining space -->
    <com.neobrowser.browser.NeoWebView
        android:id="@+id/webview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>
