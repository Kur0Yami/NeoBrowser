<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- SITE -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="SITE" android:textColor="@color/accent" android:textSize="11sp"
            android:textStyle="bold" android:layout_marginBottom="8dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Home page" android:textColor="@color/text_primary" android:textSize="14sp"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="When you tap the home icon" android:textColor="@color/text_secondary"
            android:textSize="12sp" android:layout_marginBottom="6dp"/>
        <EditText android:id="@+id/input_homepage"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="https://google.com" android:textColor="@color/text_primary"
            android:textColorHint="#555" android:background="@color/bg_card"
            android:padding="10dp" android:inputType="textUri" android:singleLine="true"/>
        <Button android:id="@+id/btn_save_homepage" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Save" android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Start page" android:textColor="@color/text_primary" android:textSize="14sp"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="When starting the app" android:textColor="@color/text_secondary"
            android:textSize="12sp" android:layout_marginBottom="6dp"/>
        <Spinner android:id="@+id/spinner_start_page"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:background="@color/bg_card" android:padding="8dp" android:layout_marginBottom="12dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="New tab" android:textColor="@color/text_primary" android:textSize="14sp"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="When creating a new tab" android:textColor="@color/text_secondary"
            android:textSize="12sp" android:layout_marginBottom="6dp"/>
        <Spinner android:id="@+id/spinner_new_tab"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:background="@color/bg_card" android:padding="8dp"/>
        <EditText android:id="@+id/input_new_tab_url"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="https://" android:textColor="@color/text_primary"
            android:textColorHint="#555" android:background="@color/bg_card"
            android:padding="10dp" android:inputType="textUri" android:singleLine="true"
            android:visibility="gone"/>
        <Button android:id="@+id/btn_save_new_tab" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Save" android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp" android:visibility="gone"/>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/bg_card" android:layout_marginVertical="8dp"/>

        <!-- DOWNLOAD -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="DOWNLOAD" android:textColor="@color/accent" android:textSize="11sp"
            android:textStyle="bold" android:layout_marginBottom="8dp"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Download manager" android:textColor="@color/text_primary" android:textSize="14sp"
            android:layout_marginBottom="6dp"/>
        <Spinner android:id="@+id/spinner_dl_manager"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:background="@color/bg_card" android:padding="8dp"/>
        <EditText android:id="@+id/input_custom_pkg"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Package name (e.g. com.example.dl)" android:textColor="@color/text_primary"
            android:textColorHint="#555" android:layout_marginTop="8dp" android:visibility="gone"/>
        <Button android:id="@+id/btn_save_pkg" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Save"
            android:layout_marginTop="4dp" android:layout_marginBottom="12dp"/>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/bg_card" android:layout_marginVertical="8dp"/>

        <!-- DISPLAY -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="DISPLAY" android:textColor="@color/accent" android:textSize="11sp"
            android:textStyle="bold" android:layout_marginBottom="8dp"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Fullscreen mode" android:textColor="@color/text_primary" android:textSize="14sp"
            android:layout_marginBottom="6dp"/>
        <Spinner android:id="@+id/spinner_fullscreen"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:background="@color/bg_card" android:padding="8dp"/>

    </LinearLayout>
</ScrollView>