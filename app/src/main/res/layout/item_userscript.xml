<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_margin="5dp"
    app:cardCornerRadius="12dp"
    app:cardBackgroundColor="@color/dark_surf"
    app:cardElevation="0dp"
    app:strokeColor="@color/dark_bord"
    app:strokeWidth="1dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="12dp" android:gap="8dp">

        <!-- Header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:gap="10dp">
            <ImageView android:id="@+id/script_icon_img"
                android:layout_width="32dp" android:layout_height="32dp"
                android:src="@drawable/ic_script" android:padding="8dp"
                android:background="@drawable/bg_chip"/>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:id="@+id/script_name"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/dark_txt" android:textSize="13sp" android:textStyle="bold"/>
                <TextView android:id="@+id/script_desc"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/dark_hint" android:textSize="11sp" android:layout_marginTop="1dp"/>
            </LinearLayout>
            <Switch android:id="@+id/script_toggle"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:thumbTint="@color/dark_acc" android:trackTint="@color/dark_bg3"/>
        </LinearLayout>

        <!-- Matches chips -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_matches"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>

        <!-- Actions -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="end" android:gap="6dp">
            <Button android:id="@+id/btn_edit_script"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content" android:layout_height="34dp"
                android:text="Edit" android:textSize="11sp" android:paddingHorizontal="10dp"/>
            <Button android:id="@+id/btn_delete_script"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content" android:layout_height="34dp"
                android:text="Delete" android:textSize="11sp" android:textColor="@color/dark_danger"
                android:paddingHorizontal="10dp"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>